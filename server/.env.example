# Copy this file to .env and fill in your values

# Get this from MongoDB Atlas → Connect → Drivers
MONGO_URI=mongodb+srv://youruser:yourpassword@cluster0.xxxxx.mongodb.net/portfolio?retryWrites=true&w=majority

# Your deployed frontend URL (e.g. https://pracheta.vercel.app)
# Leave as * during development
FRONTEND_URL=*

# Port (Render/Railway set this automatically)
PORT=5000
